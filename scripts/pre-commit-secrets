#!/usr/bin/env bash
# Pre-commit hook: block commits containing secrets/credentials.
# Installed by scripts/install-hooks.sh into each submodule.
set -euo pipefail

# Patterns that indicate secrets (case-insensitive grep -E)
SECRET_PATTERNS=(
  # Anthropic API keys
  'sk-ant-[a-zA-Z0-9_-]{20,}'
  # GitHub tokens
  'ghp_[a-zA-Z0-9]{36}'
  'gho_[a-zA-Z0-9]{36}'
  'ghu_[a-zA-Z0-9]{36}'
  'ghs_[a-zA-Z0-9]{36}'
  'github_pat_[a-zA-Z0-9_]{22,}'
  # Cloudflare tokens
  'cf[_-]?api[_-]?token'
  # AWS
  'AKIA[0-9A-Z]{16}'
  'aws_secret_access_key'
  # Generic high-entropy secrets assigned to env-style keys
  '(API_KEY|SECRET|TOKEN|PASSWORD|PRIVATE_KEY)\s*=\s*[a-zA-Z0-9/+=_-]{20,}'
  # Private keys
  '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'
)

# Files/paths to always ignore
IGNORE_PATTERNS=(
  '\.env\.example$'
  '\.env\.template$'
  'package-lock\.json$'
  'yarn\.lock$'
  'pnpm-lock\.yaml$'
  '\.test\.(ts|js)$'
  '\.spec\.(ts|js)$'
  '__tests__/'
  '__mocks__/'
  'fixtures/'
  'pre-commit-secrets$'
  'install-hooks\.sh$'
)

# Build combined regex for files to ignore
ignore_regex=""
for pattern in "${IGNORE_PATTERNS[@]}"; do
  if [ -z "$ignore_regex" ]; then
    ignore_regex="$pattern"
  else
    ignore_regex="$ignore_regex|$pattern"
  fi
done

# Build combined regex for secret patterns
secret_regex=""
for pattern in "${SECRET_PATTERNS[@]}"; do
  if [ -z "$secret_regex" ]; then
    secret_regex="$pattern"
  else
    secret_regex="$secret_regex|$pattern"
  fi
done

# Get staged files (added/modified)
staged_files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$staged_files" ]; then
  exit 0
fi

found_secrets=false

while IFS= read -r file; do
  # Skip ignored files
  if echo "$file" | grep -qE "$ignore_regex"; then
    continue
  fi

  # Skip binary files
  if ! git diff --cached --diff-filter=ACM -p -- "$file" | head -1 | grep -q "diff --git"; then
    continue
  fi

  # Only scan the staged diff (added lines)
  diff_content=$(git diff --cached -p -- "$file" | grep '^\+[^+]' | sed 's/^\+//' || true)

  if [ -z "$diff_content" ]; then
    continue
  fi

  matches=$(echo "$diff_content" | grep -inE "$secret_regex" || true)

  if [ -n "$matches" ]; then
    if [ "$found_secrets" = false ]; then
      echo ""
      echo "ERROR: Potential secrets detected in staged changes!"
      echo "======================================================="
      found_secrets=true
    fi
    echo ""
    echo "  File: $file"
    echo "$matches" | while IFS= read -r line; do
      # Truncate long lines for readability
      echo "    $(echo "$line" | cut -c1-120)"
    done
  fi
done <<< "$staged_files"

if [ "$found_secrets" = true ]; then
  echo ""
  echo "======================================================="
  echo "Commit blocked. Remove secrets before committing."
  echo ""
  echo "If this is a false positive, bypass with:"
  echo "  git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
